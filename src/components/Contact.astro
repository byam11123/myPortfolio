---
/* Contact.astro — Contact information and static form */
import profile from '../data/profile.json';
---

<section id="contact" class="neo-section" style="background: var(--color-bg-alt);">
  <div class="neo-container">
    <h2 class="section-heading">Contact</h2>

    <div class="contact-grid">
      <!-- Left: Info + social links -->
      <div class="contact-info">
        <p class="contact-intro">
          Have a project in mind, want to collaborate, or just want to say hello?
          Reach out through any of these channels.
        </p>

        <div class="contact-links">
          <!-- Email -->
          <a href={`mailto:${profile.contact.email}`} class="contact-link neo-card" style="padding: 1.25rem;">
            <span class="link-icon" style="background: var(--color-coral);">@</span>
            <div class="link-body">
              <span class="link-label">EMAIL</span>
              <span class="link-value">{profile.contact.email}</span>
            </div>
          </a>

          <!-- GitHub -->
          <a href={`https://${profile.contact.github}`} target="_blank" rel="noopener noreferrer" class="contact-link neo-card" style="padding: 1.25rem;">
            <span class="link-icon" style="background: var(--color-text); color: var(--color-bg);">GH</span>
            <div class="link-body">
              <span class="link-label">GITHUB</span>
              <span class="link-value">{profile.contact.github}</span>
            </div>
          </a>

          <!-- LinkedIn -->
          <a href={`https://${profile.contact.linkedin}`} target="_blank" rel="noopener noreferrer" class="contact-link neo-card" style="padding: 1.25rem;">
            <span class="link-icon" style="background: var(--color-blue);">IN</span>
            <div class="link-body">
              <span class="link-label">LINKEDIN</span>
              <span class="link-value">{profile.name}</span>
            </div>
          </a>

          <!-- Twitter/X -->
          <a href={`https://${profile.contact.twitter}`} target="_blank" rel="noopener noreferrer" class="contact-link neo-card" style="padding: 1.25rem;">
            <span class="link-icon" style="background: var(--color-yellow);">X</span>
            <div class="link-body">
              <span class="link-label">TWITTER / X</span>
              <span class="link-value">@{profile.contact.twitter.split('/').pop()}</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: Contact form (static) -->
      <div class="contact-form-wrapper">
        <div class="form-label neo-tag" style="background: var(--color-yellow); margin-bottom: 1.5rem;">
          SEND A MESSAGE
        </div>
        <form class="contact-form neo-card" style="padding: 2rem;" action="#" method="POST">
          <div class="form-group">
            <label for="contact-name" class="form-field-label">NAME</label>
            <input type="text" id="contact-name" name="name" class="form-input" placeholder="Your name" required />
          </div>

          <div class="form-group">
            <label for="contact-email" class="form-field-label">EMAIL</label>
            <input type="email" id="contact-email" name="email" class="form-input" placeholder="your@email.com" required />
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-field-label">MESSAGE</label>
            <textarea id="contact-message" name="message" class="form-input form-textarea" rows="5" placeholder="What's on your mind?" required></textarea>
          </div>

          <button type="submit" class="neo-btn neo-btn-primary" style="width: 100%; justify-content: center;">
            SEND MESSAGE
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .link-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    border: var(--border-w) solid var(--color-border);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .link-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .link-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .link-value {
    font-family: var(--font-body);
    font-size: 0.85rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Form styles */
  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-field-label {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .form-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border: var(--border-w) solid var(--color-border);
    box-shadow: var(--shadow-sm);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: box-shadow 80ms ease-out;
  }

  .form-input:focus {
    box-shadow: var(--shadow-md);
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
