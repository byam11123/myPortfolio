---
/* Footer.astro — Minimal neobrutalist footer */
import profile from '../data/profile.json';
const currentYear = new Date().getFullYear();
---

<footer id="footer">
  <div class="neo-container footer-inner">
    <div class="footer-left">
      <span class="footer-name">
        <span class="footer-bracket">[</span>
        {profile.name}
        <span class="footer-bracket">]</span>
      </span>
      <span class="footer-copy">© {currentYear}. All rights reserved.</span>
    </div>

    <div class="footer-right">
      <a href="#" class="footer-top neo-btn" style="padding: 0.5rem 1rem; font-size: 0.75rem;">
        ↑ TOP
      </a>
    </div>
  </div>
</footer>

<style>
  #footer {
    border-top: var(--border-w) solid var(--color-border);
    padding: 2rem 0;
    background: var(--color-text);
    color: var(--color-bg);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
  }

  .footer-bracket {
    color: var(--color-coral);
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .footer-top {
    background: var(--color-bg) !important;
    color: var(--color-text) !important;
  }
</style>
